# NexusF5 environment template.
#
# Copy to `.env` locally (gitignored) and fill in real values for
# development. CI and production values live in GitHub Actions
# secrets / environment secrets — never in a committed file.
#
# The .env file itself is NOT read by the GitHub Actions workflows.
# The workflows read the same names from `secrets.*` at the
# appropriate scope (repository secret for wave-wide values,
# environment secret for per-environment overrides). See
# runbooks/05-running-a-wave.md for the GitHub setup.

# Prometheus Pushgateway base URL. The reusable wave workflow calls
# `python -m observability.ingest.pusher` after the matrix finishes;
# if this is empty the push step is skipped (local/dev runs).
# Example: PUSHGATEWAY_URL=http://pushgateway.internal:9091
PUSHGATEWAY_URL=
